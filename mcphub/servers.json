{
  "mcpServers": {
    "context7": {
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "autoApprove": [
        "resolve-library-id",
        "query-docs"
      ],
      "command": "npx",
      "env": {
        "DEFAULT_MINIMUM_TOKENS": "6000"
      }
    },
    "git": {
      "args": [
        "mcp-server-git",
        "--repository",
        "${CWD}"
      ],
      "autoApprove": [],
      "command": "uvx",
      "disabled": false
    }
  },
  "nativeMCPServers": {
    "mcphub": {
      "autoApprove": []
    }
  }
}
